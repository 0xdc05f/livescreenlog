# Copy to .env and adjust before local run or:
#   docker compose -f deploy/docker-compose.yml --env-file .env up -d
# Never commit a real .env — only this example file belongs in git.
# Deploy guide: docs/deploy/DEPLOY.md

# --- Application (required for shared/prod deployments) ---
LIVESCREENLOG_HMAC_SECRET=replace-with-a-long-random-secret-at-least-32-chars
LIVESCREENLOG_ALLOWED_CAPTURE_ORIGINS=https://app.example.com,https://admin.example.com
LIVESCREENLOG_PROJECT_KEY=optional-global-fallback-key
LIVESCREENLOG_RETENTION_DAYS=30
LIVESCREENLOG_RATE_LIMIT_CREATE=60
LIVESCREENLOG_RATE_LIMIT_EVENTS=600

# Optional dashboard Basic Auth (only if you enable it in your deployment)
# LIVESCREENLOG_DASHBOARD_ENABLED=false
# LIVESCREENLOG_DASHBOARD_USERNAME=admin
# LIVESCREENLOG_DASHBOARD_PASSWORD=replace-with-strong-password

# --- Database / Redis (prod profile & docker app service) ---
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=livescreenlog
# DB_USER=livescreenlog_user
# DB_PASSWORD=replace-me
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# --- Optional local contributor tooling (never commit real values) ---
# FIGMA_API_KEY=
# SNYK_TOKEN=
