{
  "$schema": "https://app.kilo.ai/config.json",
  "permission": {
    "bash": "allow",
    "external_directory": {
      "/tmp/*": "allow",
      "/private/tmp/*": "allow"
    },
    "snyk_*": "ask",
    "figma_*": "ask",
    "playwright_*": "ask",
    "chrome-devtools_*": "ask",
    "chrome_devtools_*": "ask"
  },
  "mcp": {
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp", "--stdio"],
      "enabled": true,
      "timeout": 60000
    },
    "snyk": {
      "type": "local",
      "command": ["npx", "-y", "snyk@latest", "mcp", "-t", "stdio"],
      "enabled": true,
      "timeout": 120000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 120000
    },
    "chrome-devtools": {
      "type": "local",
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true,
      "timeout": 120000
    }
  }
}
